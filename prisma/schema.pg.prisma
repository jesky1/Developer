generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id           String   @id @default(cuid())
  homeTeam     String
  awayTeam     String
  homeScore    Int      @default(0)
  awayScore    Int      @default(0)
  status       String   @default("UPCOMING")
  minute       Int      @default(0)
  league       String
  leagueLogo   String   @default("")
  homeLogo     String   @default("")
  awayLogo     String   @default("")
  stadium      String   @default("")
  kickoff      String   @default("")
  isHot        Boolean  @default(false)
  events       String   @default("[]")
  homeForm     String   @default("[]")
  awayForm     String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  poll         Poll?
}

model Standing {
  id       String   @id @default(cuid())
  position Int
  team     String
  teamLogo String   @default("")
  played   Int      @default(0)
  won      Int      @default(0)
  drawn    Int      @default(0)
  lost     Int      @default(0)
  gf       Int      @default(0)
  ga       Int      @default(0)
  gd       Int      @default(0)
  points   Int      @default(0)
  league   String
  form     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Scorer {
  id        String   @id @default(cuid())
  name      String
  team      String
  teamLogo  String   @default("")
  goals     Int      @default(0)
  assists   Int      @default(0)
  matches   Int      @default(0)
  league    String
  photoUrl  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Poll {
  id        String   @id @default(cuid())
  matchId   String   @unique
  homeVotes Int      @default(0)
  drawVotes Int      @default(0)
  awayVotes Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model NewsItem {
  id             String   @id @default(cuid())
  title          String
  slug           String?  @unique
  summary        String
  content        String   @default("")
  category       String   @default("Transfer")
  imageUrl       String   @default("")
  source         String   @default("GOALZONE AI")
  tags           String   @default("[]")
  seoTitle       String   @default("")
  seoDescription String   @default("")
  keywords       String   @default("")
  league         String   @default("")
  matchId        String?
  isAiGenerated  Boolean  @default(true)
  publishedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())
}

model Player {
  id           String   @id @default(cuid())
  name         String
  firstName    String   @default("")
  lastName     String   @default("")
  photoUrl     String   @default("")
  age          Int      @default(0)
  birthDate    String   @default("")
  nationality  String   @default("")
  height       String   @default("")
  weight       String   @default("")
  position     String   @default("")
  shirtNumber  Int      @default(0)
  currentClub  String   @default("")
  clubLogo     String   @default("")
  rating       Float    @default(0)
  apiFootballId Int     @default(0)
  birthPlace   String   @default("")
  birthCountry String   @default("")
  injured      Boolean  @default(false)
  teamId       Int      @default(0)
  teamLogo     String   @default("")
  leagueId     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stats     PlayerStats?
  transfers Transfer[]
}

model PlayerStats {
  id              String   @id @default(cuid())
  playerId        String   @unique
  totalMatches    Int      @default(0)
  goals           Int      @default(0)
  assists         Int      @default(0)
  shots           Int      @default(0)
  shotsOnTarget   Int      @default(0)
  passingAccuracy Float    @default(0)
  tackles         Int      @default(0)
  interceptions   Int      @default(0)
  fouls           Int      @default(0)
  yellowCards     Int      @default(0)
  redCards        Int      @default(0)
  rating          Float    @default(0)
  season          String   @default("2024/2025")
  matchRatings    String   @default("[]")
  leagueId        Int      @default(0)
  leagueName      String   @default("")
  leagueSeason    Int      @default(0)
  teamName        String   @default("")
  lineups         Int      @default(0)
  minutes         Int      @default(0)
  goalsConceded   Int      @default(0)
  saves           Int      @default(0)
  passesTotal     Int      @default(0)
  passesKey       Int      @default(0)
  tacklesBlocks   Int      @default(0)
  duelsTotal      Int      @default(0)
  duelsWon        Int      @default(0)
  dribblesAttempts Int     @default(0)
  dribblesSuccess Int      @default(0)
  dribblesPast    Int      @default(0)
  foulsDrawn      Int      @default(0)
  foulsCommitted  Int      @default(0)
  yellowRedCards  Int      @default(0)
  penaltyWon      Int      @default(0)
  penaltyCommitted Int     @default(0)
  penaltyScored   Int      @default(0)
  penaltyMissed   Int      @default(0)
  penaltySaved    Int      @default(0)
  isCaptain       Boolean  @default(false)
  substitutesIn   Int      @default(0)
  substitutesOut  Int      @default(0)
  substitutesBench Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Transfer {
  id         String   @id @default(cuid())
  playerId   String
  fromClub   String
  toClub     String
  fromLogo   String   @default("")
  toLogo     String   @default("")
  date       String
  fee        String   @default("")
  type       String   @default("Transfer")
  createdAt  DateTime @default(now())

  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model MatchLineup {
  id          String   @id @default(cuid())
  matchId     String
  team        String
  teamName    String
  formation   String   @default("4-3-3")
  startXI     String   @default("[]")
  substitutes String   @default("[]")
  coach       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MatchStats {
  id              String   @id @default(cuid())
  matchId         String   @unique
  homePossession  Float    @default(50)
  awayPossession  Float    @default(50)
  homeShots       Int      @default(0)
  awayShots       Int      @default(0)
  homeShotsOnTarget Int    @default(0)
  awayShotsOnTarget Int    @default(0)
  homeCorners     Int      @default(0)
  awayCorners     Int      @default(0)
  homeFouls       Int      @default(0)
  awayFouls       Int      @default(0)
  homeOffsides    Int      @default(0)
  awayOffsides    Int      @default(0)
  homeYellowCards Int      @default(0)
  awayYellowCards Int      @default(0)
  homeRedCards    Int      @default(0)
  awayRedCards    Int      @default(0)
  homePassAccuracy Float   @default(0)
  awayPassAccuracy Float   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  emailVerified   DateTime?
  passwordHash    String?
  image           String   @default("")
  provider        String   @default("credentials")
  providerAccountId String @default("")
  role            String   @default("user")
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  providerType      String
  provider          String
  providerAccountId String
  refreshToken      String?  @default("")
  accessToken       String?  @default("")
  expiresAt         Int?
  tokenType         String?  @default("")
  scope             String?  @default("")
  idToken           String?  @default("")
  sessionState      String?  @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String   @id
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @default("")
  displayName  String   @default("")
  avatarUrl    String   @default("")
  role         String   @default("editor")
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activities   ActivityLog[]
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @default("")
  category    String   @default("general")
  description String   @default("")
  isPublic    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  resourceId String  @default("")
  details   String   @default("{}")
  ip        String   @default("")
  createdAt DateTime @default(now())

  user      AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PageView {
  id        String   @id @default(cuid())
  path      String   @default("/")
  referrer  String   @default("")
  country   String   @default("")
  device    String   @default("")
  browser   String   @default("")
  os        String   @default("")
  duration  Int      @default(0)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String   @default("")
  message   String
  status    String   @default("unread")
  reply     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdUnit {
  id          String   @id @default(cuid())
  name        String
  slotId      String   @unique
  placement   String
  adType      String   @default("display")
  isActive    Boolean  @default(true)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      AdEvent[]
}

model AdEvent {
  id        String   @id @default(cuid())
  adUnitId  String
  eventType String
  page      String   @default("")
  ip        String   @default("")
  userAgent String   @default("")
  country   String   @default("")
  revenue   Float    @default(0)
  createdAt DateTime @default(now())

  adUnit    AdUnit   @relation(fields: [adUnitId], references: [id], onDelete: Cascade)
}

model AdSenseReport {
  id            String   @id @default(cuid())
  date          String   @unique
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  revenue       Float    @default(0)
  ctr           Float    @default(0)
  cpc           Float    @default(0)
  rpm           Float    @default(0)
  pageViews     Int      @default(0)
  activeViewCtr Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TrafficLog {
  id        String   @id @default(cuid())
  path      String   @default("/")
  referrer  String   @default("")
  country   String   @default("")
  device    String   @default("")
  browser   String   @default("")
  os        String   @default("")
  utmSource String   @default("")
  utmMedium String   @default("")
  utmCampaign String @default("")
  sessionId String   @default("")
  duration  Int      @default(0)
  createdAt DateTime @default(now())
}

model TrendingTopic {
  id          String   @id @default(cuid())
  keyword     String
  source      String   @default("google")
  volume      Int      @default(0)
  category    String   @default("football")
  region      String   @default("global")
  isProcessed Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduledTask {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("pending")
  schedule    String   @default("")
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  result      String   @default("{}")
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TelegramPost {
  id           String   @id @default(cuid())
  newsId       String?
  chatId       String   @default("")
  message      String
  status       String   @default("pending")
  sentAt       DateTime?
  error        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model InternalLink {
  id           String   @id @default(cuid())
  sourceSlug   String
  targetSlug   String
  anchorText   String   @default("")
  createdAt    DateTime @default(now())

  @@unique([sourceSlug, targetSlug])
}